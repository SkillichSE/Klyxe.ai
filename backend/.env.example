# Required — get from Railway/Neon dashboard
DATABASE_URL=postgresql+psycopg://user:password@host:5432/klyxe
JWT_SECRET=generate-a-random-64-char-secret-here-min-16

# Environment
ENVIRONMENT=production
FRONTEND_ORIGIN=https://klyxe.ai

# LLM API (for RAG chat feature)
LLM_API_KEY=sk-or-v1-...
LLM_API_BASE=https://openrouter.ai/api/v1
LLM_DEFAULT_MODEL=openai/gpt-4o-mini
LLM_HTTP_REFERER=https://klyxe.ai
LLM_TITLE=Klyxe RAG

# Optional — S3 for file storage
S3_ENDPOINT=
S3_BUCKET=klyxe
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=auto
